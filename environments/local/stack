#!/usr/bin/env bash
# Raksha local-stack control script.
#
# Usage:
#   ./stack                 # build + start + wait for healthy (alias: ./stack up)
#   ./stack up              # same as above
#   ./stack down            # stop containers, keep DB volumes
#   ./stack down -v         # stop containers AND wipe DB volumes (fresh DB)
#   ./stack reset           # alias for `./stack down -v`
#   ./stack logs            # follow all logs
#   ./stack logs portal-backend  # follow one service
#   ./stack errors          # follow only error/warn lines (all services)
#   ./stack errors engine   # follow only error/warn lines (one service)
#   ./stack status          # print health of each service
#   ./stack qa up           # start qa-web (end-to-end test runner) on :4000
#   ./stack qa down         # stop qa-web
#   ./stack qa logs         # follow qa-web logs
set -euo pipefail

SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
cd "$SCRIPT_DIR"

COMPOSE="docker compose"
QA_FRAMEWORK_DIR="${SCRIPT_DIR}/../../../raksha-qa-framework"
QA_COMPOSE="docker compose -f ${QA_FRAMEWORK_DIR}/docker-compose.qa.yml --project-directory ${QA_FRAMEWORK_DIR}"

cmd_up() {
  echo "==> validating compose file"
  $COMPOSE config -q

  echo "==> building images (may take several minutes on first run)"
  $COMPOSE build

  echo "==> starting stack"
  $COMPOSE up -d

  echo "==> waiting for services to become healthy"
  local deadline=$(( $(date +%s) + 300 ))
  while true; do
    if status_ok; then
      echo "==> all services healthy"
      break
    fi
    if (( $(date +%s) > deadline )); then
      echo "!!! timeout waiting for services to become healthy" >&2
      cmd_status
      exit 1
    fi
    sleep 3
  done

  cmd_status
  cat <<EOF

==> endpoints
  portal (user UI)          http://localhost:3000
  admin  (ops UI)           http://localhost:3002
  platform API              http://localhost:3001   (service: portal-backend; shared by portal + admin)
  platform API Swagger      http://localhost:3001/v1/openapi
  simlab-api                http://localhost:8084   (simulation CRUD; peer-only)
  agent-api                 http://localhost:8090   (AI agents runtime; peer-only)
  rule-control-api          http://localhost:8085   (detection CRUD; peer-token)
  alert-control-api         http://localhost:8086   (delivery CRUD; peer-token)
  ingestion-gateway health  http://localhost:8080/health
  ingestion-gateway metrics http://localhost:9092/metrics
  notifier-runtime health   http://localhost:8082/health
  notifier-runtime metrics  http://localhost:9093/metrics
  engine metrics            http://localhost:9091/metrics
  minio console             http://localhost:9001  (raksha / rakshadevsecret)
  postgres                  localhost:5432         (raksha / raksha)
  redis                     localhost:6379

==> next steps
  ./stack logs            # tail all logs
  ./stack logs engine     # tail one service
  ./stack errors          # errors/warnings only (fast triage)
  ./stack errors engine   # errors for one service
  ./stack status          # re-check health
  ./stack qa up           # start e2e test runner web UI on http://localhost:4000
  ./stack down            # stop (keep data)
  ./stack reset           # stop + wipe volumes
EOF
}

cmd_qa() {
  local qa_cmd="${1:-up}"
  shift || true
  if [[ ! -d "$QA_FRAMEWORK_DIR" ]]; then
    echo "!!! raksha-qa-framework not found at $QA_FRAMEWORK_DIR" >&2
    exit 1
  fi
  case "$qa_cmd" in
    up)
      if ! docker network inspect raksha-local_default >/dev/null 2>&1; then
        echo "!!! raksha-local stack is not running. Start it first: ./stack up" >&2
        exit 1
      fi
      echo "==> building qa-web image (first run only)"
      $QA_COMPOSE build qa-web
      echo "==> starting qa-web on http://localhost:4000"
      $QA_COMPOSE up -d qa-web
      echo "==> qa-web ready. Open http://localhost:4000"
      ;;
    down)
      echo "==> stopping qa-web"
      $QA_COMPOSE down || true
      ;;
    logs)
      $QA_COMPOSE logs -f --tail=100 qa-web
      ;;
    *) echo "usage: $0 qa {up|down|logs}" >&2; exit 2 ;;
  esac
}

cmd_down() {
  # Defaults: keep Postgres/Redis/MinIO volumes so next `./stack up` is
  # fast. Pass -v / --volumes / --wipe to also drop volumes (fresh DB).
  local wipe=false
  for arg in "$@"; do
    case "$arg" in
      -v|--volumes|--wipe) wipe=true ;;
      *) echo "unknown flag: $arg (try ./stack down [-v|--volumes])" >&2; exit 2 ;;
    esac
  done
  if $wipe; then
    echo "==> stopping stack and wiping volumes (fresh DB on next up)"
    $COMPOSE down -v
  else
    echo "==> stopping stack (volumes preserved — use ./stack down -v to wipe)"
    $COMPOSE down
  fi
}

# Kept as an alias of `down -v` for muscle memory.
cmd_reset() {
  cmd_down --wipe
}

cmd_logs() {
  # ./stack logs [service...]
  $COMPOSE logs -f --tail=100 "$@"
}

# Errors-only view: filters log output to lines containing error/warn/panic
# keywords. Covers Go (ERROR, WARN, panic), Rust (ERROR, WARN), NestJS
# (ERROR, WARN), and Next.js (error, Error) output.
#
# Usage:
#   ./stack errors                     # all services
#   ./stack errors portal-backend      # one service
#   ./stack errors engine notifier-runtime  # multiple services
cmd_errors() {
  $COMPOSE logs -f --tail=500 "$@" 2>&1 \
    | grep --line-buffered -iE \
        'error|ERR|warn|WARN|panic|PANIC|fatal|FATAL|failed|FAIL|exception|unhandled|rejected|exit.*(1|code)|cannot find module|relation.*does not exist|connection refused'
}

cmd_status() {
  echo "==> service status"
  # Prints the health of each non-oneshot service.
  for svc in postgres redis minio rule-control-api alert-control-api stream-control-api simlab-api agent-api engine notifier-runtime ingestion-gateway portal-backend portal admin; do
    local health
    health=$(docker inspect -f '{{if .State.Health}}{{.State.Health.Status}}{{else}}{{.State.Status}}{{end}}' "raksha-local-${svc}-1" 2>/dev/null || echo "missing")
    printf "  %-22s %s\n" "$svc" "$health"
  done
}

status_ok() {
  for svc in postgres redis minio rule-control-api alert-control-api stream-control-api simlab-api agent-api engine notifier-runtime ingestion-gateway portal-backend portal admin; do
    local health
    health=$(docker inspect -f '{{if .State.Health}}{{.State.Health.Status}}{{else}}{{.State.Status}}{{end}}' "raksha-local-${svc}-1" 2>/dev/null || echo "missing")
    case "$health" in
      healthy|running) ;;
      *) return 1 ;;
    esac
  done
  return 0
}

cmd="${1:-up}"
shift || true
case "$cmd" in
  up)     cmd_up "$@" ;;
  down)   cmd_down "$@" ;;
  reset)  cmd_reset ;;
  logs)   cmd_logs "$@" ;;
  errors) cmd_errors "$@" ;;
  status) cmd_status ;;
  qa)     cmd_qa "$@" ;;
  *) echo "usage: $0 {up|down [-v]|reset|logs [svc]|errors [svc]|status|qa {up|down|logs}}" >&2; exit 2 ;;
esac
