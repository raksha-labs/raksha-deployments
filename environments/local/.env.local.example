# Raksha local stack environment variables.
# Copy to .env.local (gitignored) and fill in values.
# docker-compose reads .env.local automatically.

# ── Postgres ──
POSTGRES_PASSWORD=raksha

# ── MinIO ──
MINIO_ROOT_PASSWORD=rakshadevsecret

# ── Inter-service peer tokens (one per boundary pair) ──
PEER_TOKEN_ENGINE=dev-peer-token-engine-local-2026
PEER_TOKEN_NOTIFIER_GATEWAY=dev-peer-token-notifier-gateway-1
PEER_TOKEN_EVENT_GATEWAY=dev-peer-token-event-gateway-2026
PEER_TOKEN_SIMLAB=dev-peer-token-simlab-local-2026
INTERNAL_SERVICE_TOKEN=dev-service-token-local-dev-2026

# ── Portal session ──
RAKSHA_WEB_SESSION_SECRET=raksha-local-dev-session-secret-32chars
RAKSHA_ADMIN_SESSION_SECRET=raksha-local-admin-session-secret-32chars

# ── Risk monitor — Base mainnet RPC ──
# Default falls back to the public https://mainnet.base.org endpoint (rate-limited).
# Use an Alchemy URL for reliable eth_getLogs polling in the ProvisionerCache.
RISK_MONITOR_BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY_HERE
