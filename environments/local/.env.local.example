# Raksha local stack environment variables.
# Copy to .env.local (gitignored) and fill in values.
# docker-compose reads .env.local automatically.

# ── Postgres ──
POSTGRES_PASSWORD=raksha

# ── MinIO ──
MINIO_ROOT_PASSWORD=rakshadevsecret

# ── Inter-service peer tokens (one per boundary pair) ──
PEER_TOKEN_ENGINE=dev-peer-token-engine
PEER_TOKEN_NOTIFIER_GATEWAY=dev-peer-token-notifier-gateway
PEER_TOKEN_EVENT_GATEWAY=dev-peer-token-event-gateway
PEER_TOKEN_SIMLAB=dev-peer-token-simlab
INTERNAL_SERVICE_TOKEN=dev-service-token-local

# ── Portal session ──
RAKSHA_WEB_SESSION_SECRET=raksha-local-dev-session-secret-32chars
RAKSHA_ADMIN_SESSION_SECRET=raksha-local-admin-session-secret-32chars
